local function AutoFight()
    local Character = Player.Character
    local Living = workspace.Living
    local function FindMob()
        local PlayerFight = Character:FindFirstChild("FightInProgress")
        if PlayerFight then
            PlayerFight = PlayerFight.Value
            for _, Mob in Living:GetChildren() do
                if not Players:GetPlayerFromCharacter(Mob) then
                    local MobFight = Mob:FindFirstChild("FightInProgress")
                    if MobFight and MobFight.Value == PlayerFight then
                        return Mob
                    end
                end
            end
        end
    end
    local args = {"Attack", "Strike"} -- 3 {["Attacking"] = Model}
    local Input = game:GetService("ReplicatedStorage"):WaitForChild("PlayerTurnInput")-- :InvokeServer(unpack(args), Model)
    local AttackType = "Strike" -- "Strike" "Magic Missile"
    while task.wait(0.25) do
        local FoundMob = FindMob()
        if FoundMob then
            Input:InvokeServer("Attack", "Perennial Canopy", {["Attacking"] = FoundMob})	
            task.wait(0.1)
            Input:InvokeServer("Attack", "Stinger", {["Attacking"] = FoundMob})
            task.wait(0.1)
            Input:InvokeServer("Attack", "Surprise Package", {["Attacking"] = FoundMob})
            task.wait(0.1)
            Input:InvokeServer("Attack", "Enrichment", {["Attacking"] = Character})
            task.wait(0.1)
            Input:InvokeServer("Attack", "Expose", {["Attacking"] = FoundMob})
            task.wait(0.1)
            Input:InvokeServer("Attack", "Flourish", {["Attacking"] = FoundMob})
            task.wait(0.1)
            Input:InvokeServer("Attack", AttackType, {["Attacking"] = FoundMob})
            task.wait(0.1)
            Input:InvokeServer("Meditate", false)
        end
    end
end
