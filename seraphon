local function AutoQTE()
    local Info = game.ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Information")

    local CombatFunc = Info:WaitForChild("RemoteFunction")
    local EnviroFunc = Info:WaitForChild("EnviroEffects")
    local ClonedCombatFunc = cloneref(CombatFunc)

    local AutoQTEEvent = ClonedCombatFunc.OnClientEvent:Connect(function(a1, a2)
        warn("Init: ", a1, a2)
        if a1 == "DodgeMinigame" then
            for _ = 1, 3 do
                ClonedCombatFunc:FireServer({true, true}, a1)
                task.wait(0.1)
            end
        elseif a1:find("QTE") then
            for _ = 1, 3 do
                ClonedCombatFunc:FireServer(true, a1)
                task.wait(0.1)
            end
        end
    end)

    CombatFunc.Parent = game
    EnviroFunc.Parent = game

    if hookinstance then
        hookinstance(CombatFunc, Instance.new("RemoteEvent"))
        hookinstance(EnviroFunc, Instance.new("RemoteEvent"))
    end
    --
    if not shared.IsExecuted01 then
        shared.IsExecuted01 = true
        for _, Object in ipairs(workspace:GetDescendants()) do
            if Object.Name:lower() == "void" then
                spawn(function()
                    print("DELETED VOID")
                    Object:Destroy()
                end)
            end
        end
        workspace.DescendantAdded:Connect(function(Object) --< replace w getnilinstances later
            if Object.Name:lower() == "void" then
                spawn(function()
                    warn("DELETED VOID")
                    Object:Destroy()
                end)
            end
        end)

        local Lighting = game:GetService("Lighting")
        for _, Object in ipairs(Lighting:GetDescendants()) do
            Object:Destroy()
        end
        local AmbientColor = Color3.fromRGB(255, 255, 255)
        Lighting.Ambient = AmbientColor
        Lighting.OutdoorAmbient = AmbientColor
        Lighting.ColorShift_Bottom = AmbientColor
        Lighting.ColorShift_Top = AmbientColor
        Lighting.Brightness = 1

        for _, UI in ipairs(Player.PlayerGui.Combat:GetChildren()) do
            local UIName = UI.Name:lower()
            if UIName:find("qte") or UIName:find("block") or UIName == "go" then
                UI.Position = UDim2.fromScale(100, 100)
            end
        end
    end
    return AutoQTEEvent
end
