task.spawn(function()
    local local_player = game:GetService("Players").LocalPlayer
    local workspace = game:GetService("Workspace")

    getgenv().aura_settings = {
        enabled = not (aura_settings and aura_settings.enabled),
        delay = 0 -- delay to hitting nearby enemies
    }
    warn(aura_settings.enabled)

    function current_damage()
        return 9e99
    end

    local RemoteHit = Remotes:WaitForChild("onHit")
    --local RemoteSwing = Remotes:WaitForChild("swing")

    local WhitelistedNames = {
        "kori", "dragon", "korl"
    }
    local BlacklistedNames = {
        "kori_rig", "koribossfight"
    }
    local AllyNames = {
        "shroom"
    }
    local function CheckSpecialEnemy(Model)
        local ModelName = Model.Name:lower()
        for _, MatchString in next, WhitelistedNames do
            if ModelName:find(MatchString) and not table.find(BlacklistedNames, ModelName) then
                return true
            end
        end
    end
    local function CheckAlly(Model)
        local ModelName = Model.Name:lower()
        for _, MatchString in next, AllyNames do
            if ModelName:find(MatchString) then
                return true
            end
        end
    end

    if aura_settings.enabled then
        repeat
            for _, v in ipairs(workspace:GetChildren()) do
                local IsKori = CheckSpecialEnemy(v)
                local IsAlly = CheckAlly(v)
                if v ~= local_player.Character and v:IsA("Model") and not IsAlly then
                    local TargetHuman = v:FindFirstChildOfClass("Humanoid") or (v:FindFirstChildOfClass("Model") and v:FindFirstChildOfClass("Model"):FindFirstChildOfClass("Humanoid"))
                    if IsKori or TargetHuman and TargetHuman.Health > 0 then
                        if IsKori or v:GetAttribute("hadEntrance") and v:FindFirstChild("Health") then
                            --warn(TargetHuman, v)
                            RemoteHit:FireServer(TargetHuman, current_damage(), {}, 0)
                        end
                    end
                end
            end
            task.wait(aura_settings.delay)
        until not aura_settings.enabled
    end
end)
